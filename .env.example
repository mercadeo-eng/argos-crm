# ─────────────────────────────────────────────────────────────────────────
# Argos CRM — environment variables
# ─────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` and fill in real values for the things
# you want to use. Anything you leave commented out falls back to the
# default shown next to it.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser bundle.
# Treat anything WITHOUT that prefix as a server-side secret — never
# commit it to git, never expose it to the client.

# ════════════════════════════════════════════════════════════════════════
# 1. DEMO MODE
# ════════════════════════════════════════════════════════════════════════
# Default: true. When demo mode is active the app bypasses Supabase, signs
# in an admin automatically, seeds 8 fictional clients and persists every
# change to localStorage. Set this to "false" once you wire up Supabase.
#
# NEXT_PUBLIC_DEMO_MODE=false

# ════════════════════════════════════════════════════════════════════════
# 2. BRANDING
# ════════════════════════════════════════════════════════════════════════
# All optional. If unset, the app falls back to "Argos CRM" / its tagline.

# The product name shown in the wordmark and as the document <title>.
# NEXT_PUBLIC_APP_NAME="Acme CRM"

# Meta description.
# NEXT_PUBLIC_APP_TAGLINE="CRM for agencies and teams"

# Optional logo URL. If set, replaces the text wordmark with an <img>.
# NEXT_PUBLIC_LOGO_URL="https://example.com/logo.svg"

# ════════════════════════════════════════════════════════════════════════
# 3. UI LABELS (override per-buyer terminology without forking i18n)
# ════════════════════════════════════════════════════════════════════════
# If unset, the labels come from the active i18n locale (es/en).
# Setting these "locks" the label across all languages — useful when your
# vertical has a specific term (e.g. "Pautas" for an ad agency).

# NEXT_PUBLIC_LABEL_METRICS_MODULE="Pautas"
# NEXT_PUBLIC_LABEL_METRICS_MODULE_GLOBAL="Pautas global"
# NEXT_PUBLIC_LABEL_REPORT_TITLE="Informe completo"

# ════════════════════════════════════════════════════════════════════════
# 4. PIPELINE STAGES
# ════════════════════════════════════════════════════════════════════════
# Override the default stage list with a JSON array. Each stage requires
# id (string), label (string), icon (string) and optionally
# hasDeliverable (boolean — shows the "Open" button when the stage is
# marked Ready). If unset, the default 8-stage content pipeline is used.
#
# NEXT_PUBLIC_STAGES_JSON='[{"id":"discovery","label":"Discovery","icon":"🔍","hasDeliverable":true},{"id":"build","label":"Build","icon":"🛠️","hasDeliverable":true},{"id":"review","label":"Review","icon":"👀"},{"id":"closed","label":"Closed","icon":"✅"}]'

# Team capacity per day (used by the heatmap and load coloring).
# NEXT_PUBLIC_TEAM_DAILY_CAPACITY=8

# ════════════════════════════════════════════════════════════════════════
# 5. SUPABASE (required when demo mode is off)
# ════════════════════════════════════════════════════════════════════════
# Create a Supabase project at https://supabase.com, run the migrations
# in supabase/migrations/*.sql in order, then paste the values here.
#
# - Project URL — Settings → API → Project URL
# - Anon key   — Settings → API → Project API keys → anon public
# - Service role — Settings → API → Project API keys → service_role
#   (SERVER-ONLY: bypasses RLS; never expose to the client)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ════════════════════════════════════════════════════════════════════════
# 6. GOOGLE OAUTH (optional — for Google Calendar sync)
# ════════════════════════════════════════════════════════════════════════
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-domain.com/api/google/callback
# Required scopes: calendar.events, calendar.readonly
#
# If you don't need calendar sync, leave both empty — the "Connect Google
# Calendar" button will simply show as not-connected.

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ════════════════════════════════════════════════════════════════════════
# 7. OPTIONAL — external leads tool link
# ════════════════════════════════════════════════════════════════════════
# If your workflow has an external leads/pipeline tool, set its URL here.
# The "Open external tool" card in the Leads tab only renders when this
# variable is set.
#
# NEXT_PUBLIC_LEADS_EXTERNAL_URL="https://your-leads-tool.example.com"
